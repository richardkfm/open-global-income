{
  "name": "open-global-income",
  "version": "0.1.10",
  "description": "Open standard and reference implementation for a global income entitlement calculation model",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "data:update": "tsx src/data/importer.ts",
    "data:update:wb": "tsx src/data/worldbank/importer.ts",
    "data:update:ilo": "tsx src/data/ilo/importer.ts",
    "data:update:imf": "tsx src/data/imf/importer.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "sdk:generate": "tsx scripts/generate-sdk.ts",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "global-income",
    "ppp",
    "entitlement",
    "open-data",
    "economic-indicators"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.7"
  }
}
