# Open Global Income — environment variable reference
# Copy to .env and fill in values before running with docker compose.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info           # trace | debug | info | warn | error

# ── Database ──────────────────────────────────────────────────────────────────
DB_BACKEND=sqlite        # sqlite (default) | postgres
DB_PATH=./data/ogi.sqlite  # SQLite file path (ignored when DB_BACKEND=postgres)

# PostgreSQL — required only when DB_BACKEND=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL=true            # enforce SSL on the postgres connection (default: true)

# ── Security (MUST be changed in production) ──────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Require a valid X-Api-Key header on every API request (default: false)
API_KEY_REQUIRED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*            # restrict to your frontend origin in production
CORS_METHODS=GET,POST,OPTIONS

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100       # max requests per window per IP
RATE_LIMIT_WINDOW_MS=60000  # window size in milliseconds (60 s)

# ── API behaviour ─────────────────────────────────────────────────────────────
BATCH_MAX_ITEMS=50       # max items accepted in a batch calculation request

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_ADMIN=true        # mount the /admin UI
ENABLE_METRICS=true      # expose /metrics (Prometheus)
ENABLE_AUDIT_LOG=true    # record every API request in audit_log table
